---
import Layout from '../../layouts/Layout.astro';
import { courseStudyGuides } from '../../data/comps';

const guideOrder = ['SAASS 601', 'SAASS 600', 'SAASS 627', 'SAASS 628', 'SAASS 632', 'SAASS 633', 'SAASS 660', 'SAASS 644', 'SAASS 667'];

const orderLookup = new Map(guideOrder.map((course, index) => [course, index]));

const guides = Object.entries(courseStudyGuides)
  .map(([courseKey, guide]) => {
    const ideaCount = guide.books.reduce((sum, book) => sum + book.mainIdeas.length, 0);
    const linkCount = guide.books.reduce((sum, book) => sum + book.connectedBooks.length, 0);

    return {
      courseKey,
      ...guide,
      bookCount: guide.books.length,
      ideaCount,
      linkCount,
    };
  })
  .sort((a, b) => {
    const aOrder = orderLookup.get(a.course) ?? Number.MAX_SAFE_INTEGER;
    const bOrder = orderLookup.get(b.course) ?? Number.MAX_SAFE_INTEGER;

    if (aOrder !== bOrder) {
      return aOrder - bOrder;
    }

    return a.course.localeCompare(b.course);
  });
---

<Layout title="Comps Study Guides - Shrink" description="Course-by-course study guides for comps prep.">
  <section class="comps-home">
    <header class="hero">
      <p class="eyebrow">Comps Prep</p>
      <h1>Course study guides built for fast review.</h1>
      <p class="lede">
        Each page is meant to keep the covers, authors, distilled arguments, and book-to-book links in one scannable place.
      </p>
    </header>

    <div class="guide-grid">
      {guides.map((guide) => (
        <a href={`/comps/${guide.courseKey}`} class="guide-card">
          <div class="card-topline">
            <span class="course-code">{guide.course}</span>
            <span class="pill">{guide.shortTitle}</span>
          </div>
          <h2>{guide.pageTitle}</h2>
          <p class="card-copy">{guide.description}</p>
          <dl class="stats">
            <div>
              <dt>Books</dt>
              <dd>{guide.bookCount}</dd>
            </div>
            <div>
              <dt>Main Ideas</dt>
              <dd>{guide.ideaCount}</dd>
            </div>
            <div>
              <dt>Connections</dt>
              <dd>{guide.linkCount}</dd>
            </div>
          </dl>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .comps-home {
    display: grid;
    gap: 2rem;
  }

  .hero {
    padding: clamp(2rem, 5vw, 3.5rem);
    border: 1px solid var(--border-color);
    border-radius: 28px;
    background:
      radial-gradient(circle at top left, rgba(176, 95, 55, 0.12), transparent 36%),
      linear-gradient(135deg, rgba(11, 31, 58, 0.06), transparent 55%),
      var(--surface-color);
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.78rem;
    color: var(--muted-text);
  }

  h1 {
    margin: 0;
    max-width: 14ch;
    font-size: clamp(2.3rem, 5vw, 4rem);
    line-height: 0.95;
    font-family: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', Georgia, serif;
  }

  .lede {
    max-width: 60ch;
    margin: 1rem 0 0;
    font-size: 1.05rem;
    color: var(--text-subtle);
  }

  .guide-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .guide-card {
    --card-accent: 123, 164, 214;
    --card-accent-strong: #466794;
    display: grid;
    gap: 1.15rem;
    padding: 1.5rem;
    border-radius: 24px;
    border: 1px solid rgba(var(--card-accent), 0.28);
    background:
      linear-gradient(180deg, rgba(var(--card-accent), 0.18), rgba(255, 255, 255, 0.94) 38%),
      var(--surface-color);
    color: inherit;
    text-decoration: none;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
    text-align: center;
    align-content: start;
  }

  .guide-card:hover {
    transform: translateY(-4px);
    text-decoration: none;
    border-color: rgba(var(--card-accent), 0.48);
    box-shadow: 0 24px 50px rgba(15, 23, 42, 0.12);
  }

  .card-topline {
    display: grid;
    justify-items: center;
    gap: 0.7rem;
  }

  .course-code {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted-text);
  }

  .pill {
    padding: 0.32rem 0.7rem;
    border-radius: 999px;
    background: rgba(var(--card-accent), 0.18);
    color: var(--card-accent-strong);
    font-size: 0.82rem;
    font-weight: 600;
    max-width: 100%;
    overflow-wrap: anywhere;
    text-wrap: balance;
  }

  h2 {
    margin: 0;
    font-size: 1.35rem;
    text-wrap: balance;
  }

  .card-copy {
    margin: 0;
    color: var(--text-subtle);
    text-wrap: pretty;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin: 0;
  }

  .stats div {
    min-width: 0;
    min-height: 6.75rem;
    padding: 0.9rem 0.8rem;
    border-radius: 18px;
    border: 1px solid rgba(var(--card-accent), 0.18);
    background: rgba(255, 255, 255, 0.72);
    display: grid;
    align-content: center;
    justify-items: center;
    gap: 0.3rem;
  }

  dt {
    margin: 0;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted-text);
    line-height: 1.35;
    text-wrap: balance;
  }

  dd {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 700;
  }

  .guide-card:nth-child(5n + 1) {
    --card-accent: 128, 157, 219;
    --card-accent-strong: #445fa6;
  }

  .guide-card:nth-child(5n + 2) {
    --card-accent: 121, 176, 160;
    --card-accent-strong: #2d6f63;
  }

  .guide-card:nth-child(5n + 3) {
    --card-accent: 208, 160, 118;
    --card-accent-strong: #8d5327;
  }

  .guide-card:nth-child(5n + 4) {
    --card-accent: 203, 145, 162;
    --card-accent-strong: #92526a;
  }

  .guide-card:nth-child(5n + 5) {
    --card-accent: 162, 150, 211;
    --card-accent-strong: #5d4fa0;
  }

  :root[data-theme='dark'] .hero {
    background:
      radial-gradient(circle at top left, rgba(245, 158, 11, 0.15), transparent 36%),
      linear-gradient(135deg, rgba(96, 165, 250, 0.14), transparent 55%),
      var(--surface-color);
  }

  :root[data-theme='dark'] .guide-card {
    border-color: rgba(var(--card-accent), 0.32);
    background:
      linear-gradient(180deg, rgba(var(--card-accent), 0.2), rgba(17, 28, 46, 0.94) 38%),
      var(--surface-color);
    box-shadow: 0 18px 45px rgba(2, 8, 23, 0.35);
  }

  :root[data-theme='dark'] .pill {
    color: rgba(255, 255, 255, 0.9);
    background: rgba(var(--card-accent), 0.22);
  }

  :root[data-theme='dark'] .stats div {
    background: rgba(15, 23, 42, 0.38);
    border-color: rgba(var(--card-accent), 0.22);
  }
  
  @media (max-width: 720px) {
    .stats {
      grid-template-columns: 1fr;
    }
  }
</style>
