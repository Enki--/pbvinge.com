---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { courseStudyGuides } from '../../data/comps';

export async function getStaticPaths() {
  return Object.keys(courseStudyGuides).map((course) => ({
    params: { course },
  }));
}

const { course } = Astro.params;
const guide = course ? courseStudyGuides[course] : undefined;

if (!guide) {
  throw new Error(`Unknown comps course: ${course}`);
}

const noteBooks = await getCollection('books', ({ data }) => data.class === course && data.status === 'complete');
const noteHrefByTitle = new Map(
  noteBooks.map((book) => [book.data.title.trim().toLowerCase(), `/books/${book.slug}`]),
);

const books = guide.books.map((book) => ({
  ...book,
  noteHref: noteHrefByTitle.get(book.canonicalTitle.trim().toLowerCase()),
}));

const totalIdeas = books.reduce((sum, book) => sum + book.mainIdeas.length, 0);
const totalConnections = books.reduce((sum, book) => sum + book.connectedBooks.length, 0);

const themeCounts = new Map<string, number>();

for (const book of books) {
  for (const theme of book.themes) {
    themeCounts.set(theme, (themeCounts.get(theme) || 0) + 1);
  }
}

const rankedThemes = Array.from(themeCounts.entries())
  .sort((a, b) => {
    if (b[1] !== a[1]) return b[1] - a[1];
    return a[0].localeCompare(b[0]);
  });

const defaultThemes = rankedThemes.slice(0, 8);
---

<Layout title={`${guide.pageTitle} - Shrink`} description={guide.description}>
  <section class="study-wall">
    <header class="hero">
      <div class="hero-copy">
        <p class="eyebrow">{guide.course}</p>
        <h1>{guide.pageTitle}</h1>
        <p class="lede">
          Cover-first for fast recall, with each book distilled into three main ideas and expandable connection notes.
        </p>
      </div>

      <div class="hero-stats" aria-label="Course summary">
        <div class="stat-card">
          <span class="stat-label">Books</span>
          <strong>{books.length}</strong>
        </div>
        <div class="stat-card">
          <span class="stat-label">Main Ideas</span>
          <strong>{totalIdeas}</strong>
        </div>
        <div class="stat-card">
          <span class="stat-label">Connections</span>
          <strong>{totalConnections}</strong>
        </div>
      </div>
    </header>

    <section class="books-grid" aria-label={`${guide.course} study books`}>
      {books.map((book) => (
        <article class="study-card" data-study-card data-themes={book.themes.join('|').toLowerCase()}>
          <div class="card-shell">
            <div class="card-primary">
              <div class="cover-column">
                <img src={book.coverArt} alt={`Cover of ${book.canonicalTitle}`} loading="lazy" />
              </div>

              <header class="card-header">
                {book.noteHref ? (
                  <a href={book.noteHref} class="title-link">
                    <h3>{book.canonicalTitle}</h3>
                  </a>
                ) : (
                  <h3>{book.canonicalTitle}</h3>
                )}
                {book.subtitle && <p class="subtitle">{book.subtitle}</p>}
                <p class="authors">{book.authors.join(' · ')}</p>
              </header>
            </div>

            <section class="ideas-block">
              <p class="block-label">3 main ideas</p>
              <ul>
                {book.mainIdeas.map((idea) => (
                  <li>
                    <span class="idea-bullet" aria-hidden="true"></span>
                    <span class="idea-copy">{idea}</span>
                  </li>
                ))}
              </ul>
            </section>

            <div class="card-foot">
              <section class="themes-block">
                <p class="block-label">Themes</p>
                <div class="theme-tags">
                  {book.themes.slice(0, 3).map((theme) => (
                    <span class="tag">{theme}</span>
                  ))}
                </div>
              </section>

              <section class="connections-block">
                <p class="block-label">Connected books</p>
                <ul class="connection-list">
                  {book.connectedBooks.map((connection) => (
                    <li class="connection-item">
                      <span class="connection-bullet" aria-hidden="true"></span>
                      <div class="connection-body">
                        <div class="connection-heading">
                          <strong>{connection.title}</strong>
                          <span class="relation-pill">{connection.relation}</span>
                        </div>
                        <p class="connection-copy">{connection.explanation}</p>
                      </div>
                    </li>
                  ))}
                </ul>
              </section>
            </div>
          </div>
        </article>
      ))}
    </section>

    <section class="theme-panel" aria-labelledby="theme-heading">
      <div class="theme-panel-header">
        <div>
          <p class="panel-label">Recurring themes</p>
          <h2 id="theme-heading">Filter the wall by concept.</h2>
        </div>
        <button class="theme-chip theme-chip-active" type="button" data-theme-filter="all" aria-pressed="true">
          All books
        </button>
      </div>

      <div class="theme-row">
        {defaultThemes.map(([theme, count]) => (
          <button type="button" class="theme-chip" data-theme-filter={theme} aria-pressed="false">
            <span>{theme}</span>
            <span class="theme-count">{count}</span>
          </button>
        ))}
      </div>
    </section>
  </section>

  <script is:inline>
    const filterButtons = Array.from(document.querySelectorAll('[data-theme-filter]'));
    const studyCards = Array.from(document.querySelectorAll('[data-study-card]'));

    function setThemeFilter(selectedTheme) {
      filterButtons.forEach((button) => {
        const isActive = button.dataset.themeFilter === selectedTheme;
        button.classList.toggle('theme-chip-active', isActive);
        button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });

      studyCards.forEach((card) => {
        const themes = card.dataset.themes || '';
        const matches = selectedTheme === 'all' || themes.includes(selectedTheme.toLowerCase());
        card.toggleAttribute('hidden', !matches);
      });
    }

    filterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        setThemeFilter(button.dataset.themeFilter || 'all');
      });
    });
  </script>
</Layout>

<style>
  :global(:root) {
    --page-max-width: 100vw;
  }

  :global(.site-main) {
    padding: 1rem clamp(1rem, 2vw, 1.75rem) 1.5rem;
  }

  .study-wall {
    --study-accent: #0f2742;
    --study-accent-soft: #dbe6f4;
    --study-signal: #b05f37;
    --study-signal-soft: #f7e4db;
    --study-surface: color-mix(in srgb, var(--surface-color) 92%, #f7f0e8 8%);
    display: grid;
    gap: 1rem;
    width: min(1980px, 100%);
    margin: 0 auto;
  }

  .hero,
  .theme-panel,
  .study-card {
    border: 1px solid var(--border-color);
    border-radius: 28px;
    background: var(--study-surface);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.8fr);
    gap: 0.8rem;
    padding: clamp(0.85rem, 1.4vw, 1.1rem) clamp(0.95rem, 1.8vw, 1.2rem);
    background:
      radial-gradient(circle at top left, rgba(176, 95, 55, 0.18), transparent 35%),
      linear-gradient(135deg, rgba(15, 39, 66, 0.1), transparent 50%),
      var(--study-surface);
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
  }

  .eyebrow,
  .panel-label,
  .block-label,
  .stat-label {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.76rem;
    color: var(--muted-text);
  }

  h1 {
    margin: 0;
    max-width: none;
    font-size: clamp(1.6rem, 2.6vw, 2.65rem);
    line-height: 0.95;
    font-family: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', Georgia, serif;
  }

  .lede {
    max-width: 72ch;
    margin: 0.35rem 0 0;
    font-size: 0.86rem;
    line-height: 1.35;
    color: var(--text-subtle);
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.55rem;
    align-self: end;
  }

  .stat-card {
    display: grid;
    gap: 0.18rem;
    padding: 0.6rem 0.72rem;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(15, 39, 66, 0.08);
    backdrop-filter: blur(6px);
  }

  .stat-card strong {
    font-size: clamp(1.2rem, 2vw, 1.65rem);
    line-height: 1;
    color: var(--study-accent);
  }

  .theme-panel {
    padding: 0.9rem 1rem;
  }

  .theme-panel-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1rem;
  }

  h2 {
    margin: 0.1rem 0 0;
    font-size: 1.05rem;
  }

  .theme-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .theme-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.46rem 0.72rem;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    background: var(--background-color);
    color: var(--text-color);
    font: inherit;
    cursor: pointer;
    transition: background 150ms ease, color 150ms ease, border-color 150ms ease, transform 150ms ease;
  }

  .theme-chip:hover {
    transform: translateY(-1px);
    border-color: rgba(176, 95, 55, 0.35);
  }

  .theme-chip-active {
    background: var(--study-accent);
    border-color: var(--study-accent);
    color: #f8fafc;
  }

  .theme-count {
    display: inline-grid;
    place-items: center;
    min-width: 1.5rem;
    height: 1.5rem;
    padding: 0 0.35rem;
    border-radius: 999px;
    background: rgba(15, 39, 66, 0.08);
    font-size: 0.76rem;
    font-weight: 700;
  }

  .theme-chip-active .theme-count {
    background: rgba(248, 250, 252, 0.14);
  }

  .books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 0.8rem;
  }

  .study-card {
    overflow: clip;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
  }

  .card-shell {
    display: grid;
    gap: 0.62rem;
    padding: 0.82rem;
    height: 100%;
    align-content: start;
  }

  .card-primary {
    display: grid;
    grid-template-columns: 82px minmax(0, 1fr);
    gap: 0.68rem;
    align-items: start;
  }

  .cover-column {
    display: flex;
    align-items: start;
  }

  .cover-column img {
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    border-radius: 18px;
    border: 1px solid rgba(15, 39, 66, 0.08);
    box-shadow: 0 18px 35px rgba(15, 23, 42, 0.16);
    background: var(--surface-muted-color);
  }

  .relation-pill {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    line-height: 1;
    padding: 0.32rem 0.58rem;
    background: rgba(15, 39, 66, 0.08);
    color: var(--study-accent);
  }

  .card-header h3 {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.04;
  }

  .title-link {
    color: inherit;
    text-decoration: none;
  }

  .title-link:hover {
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
  }

  .subtitle,
  .authors {
    margin: 0.3rem 0 0;
  }

  .subtitle {
    color: var(--text-strong);
    font-size: 0.82rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .authors {
    color: var(--text-subtle);
    font-size: 0.84rem;
  }

  .ideas-block ul {
    margin: 0.4rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.28rem;
  }

  .ideas-block {
    min-height: 9rem;
  }

  .ideas-block li {
    color: var(--text-strong);
  }

  .ideas-block li {
    display: grid;
    grid-template-columns: 0.7rem minmax(0, 1fr);
    gap: 0.45rem;
    align-items: start;
  }

  .idea-bullet {
    width: 0.42rem;
    height: 0.42rem;
    margin-top: 0.38rem;
    border-radius: 999px;
    background: var(--study-signal);
    box-shadow: 0 0 0 4px rgba(176, 95, 55, 0.12);
  }

  .idea-copy {
    font-size: 0.8rem;
    line-height: 1.32;
  }

  .card-foot {
    display: grid;
    gap: 0.58rem;
    align-content: start;
  }

  .themes-block {
    min-height: 3.6rem;
  }

  .theme-tags {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.4rem;
    margin-top: 0.4rem;
    overflow: hidden;
  }

  .tag {
    padding: 0.34rem 0.62rem;
    border-radius: 999px;
    font-size: 0.77rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: calc((100% - 0.8rem) / 3);
    flex: 0 1 auto;
  }

  .tag {
    background: var(--study-accent-soft);
    color: var(--study-accent);
  }

  .connection-list {
    display: grid;
    gap: 0.38rem;
    margin: 0.45rem 0 0;
    padding: 0;
    list-style: none;
    align-content: start;
  }

  .connection-item {
    display: grid;
    grid-template-columns: 0.7rem minmax(0, 1fr);
    gap: 0.45rem;
    align-items: start;
  }

  .connection-bullet {
    width: 0.42rem;
    height: 0.42rem;
    margin-top: 0.38rem;
    border-radius: 999px;
    background: var(--study-signal);
    box-shadow: 0 0 0 4px rgba(176, 95, 55, 0.12);
  }

  .connection-body {
    min-width: 0;
  }

  .connection-heading {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 0.25rem;
  }

  .connection-heading strong {
    font-size: 0.8rem;
    line-height: 1.3;
  }

  .connection-copy {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.32;
    color: var(--text-strong);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  [hidden] {
    display: none !important;
  }

  :root[data-theme='dark'] .study-wall {
    --study-accent: #bfdbfe;
    --study-accent-soft: rgba(147, 197, 253, 0.18);
    --study-signal-soft: rgba(251, 146, 60, 0.18);
    --study-surface: color-mix(in srgb, var(--surface-color) 90%, #111827 10%);
  }

  :root[data-theme='dark'] .hero {
    box-shadow: 0 24px 60px rgba(2, 8, 23, 0.35);
  }

  :root[data-theme='dark'] .stat-card {
    background: rgba(15, 23, 42, 0.45);
    border-color: rgba(148, 163, 184, 0.12);
  }

  :root[data-theme='dark'] .idea-bullet {
    box-shadow: 0 0 0 4px rgba(251, 146, 60, 0.15);
  }

  :root[data-theme='dark'] .connection-bullet {
    box-shadow: 0 0 0 4px rgba(251, 146, 60, 0.15);
  }

  @media (min-width: 1700px) {
    .books-grid {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }
  }

  @media (min-width: 1360px) and (max-width: 1699px) {
    .books-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (max-width: 1100px) {
    .hero {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 860px) {
    .books-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .theme-panel-header {
      flex-direction: column;
      align-items: start;
    }

    .hero-stats {
      grid-template-columns: 1fr;
    }

    .card-shell {
      grid-template-columns: 1fr;
    }

    .cover-column {
      justify-content: center;
    }

    .cover-column img {
      max-width: 180px;
    }

  }
</style>
